{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"lib": [
			"ES2022"
		],
		"sourceMap": true,
		"rootDir": ".",
		"strict": true,
		"skipLibCheck": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"allowUnreachableCode": false,
		"noFallthroughCasesInSwitch": true,
		"paths": {
			"@pixel-agents/core": ["./packages/core/src/index.ts"],
			"@pixel-agents/core/*": ["./packages/core/src/*"],
			"@pixel-agents/server": ["./packages/server/src/index.ts"],
			"@pixel-agents/server/*": ["./packages/server/src/*"]
		}
	},
	"include": [
		"packages/vscode",
		"packages/server/src",
		"packages/core/src"
	],
	"exclude": [
		"node_modules",
		"packages/client",
		"dist",
		"out",
		"scripts"
	]
}
